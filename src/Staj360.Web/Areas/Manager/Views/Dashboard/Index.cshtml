@model Staj360.Web.Areas.Manager.Models.ManagerDashboardViewModel
@{
    ViewData["Title"] = "Yönetici Paneli";
    var tz = (Staj360.Application.Abstractions.ITimeZoneService)Context.RequestServices.GetService(typeof(Staj360.Application.Abstractions.ITimeZoneService))!;
}
<h1 class="h4 mb-4">Yönetici Paneli</h1>
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3"><div class="card stat-card"><div class="card-body d-flex align-items-center gap-3"><i class="bi bi-diagram-3 fs-2 text-primary"></i><div><div class="stat-value">@Model.UnitCount</div><div class="stat-label">Birimlerim</div></div></div></div></div>
    <div class="col-6 col-md-3"><div class="card stat-card"><div class="card-body d-flex align-items-center gap-3"><i class="bi bi-people fs-2 text-success"></i><div><div class="stat-value">@Model.InternCount</div><div class="stat-label">Stajyerler</div></div></div></div></div>
    <div class="col-6 col-md-3"><div class="card stat-card"><div class="card-body d-flex align-items-center gap-3"><i class="bi bi-calendar-x fs-2 text-warning"></i><div><div class="stat-value">@Model.PendingLeaveCount</div><div class="stat-label">Bekleyen İzin</div></div></div></div></div>
    <div class="col-6 col-md-3"><div class="card stat-card"><div class="card-body d-flex align-items-center gap-3"><i class="bi bi-arrow-left-right fs-2 text-danger"></i><div><div class="stat-value">@Model.PendingTransferCount</div><div class="stat-label">Bekleyen Transfer</div></div></div></div></div>
    <div class="col-6 col-md-3"><div class="card stat-card"><div class="card-body d-flex align-items-center gap-3"><i class="bi bi-kanban fs-2 text-primary"></i><div><div class="stat-value">@Model.ActiveProjectCount</div><div class="stat-label">Aktif Projeler</div></div></div></div></div>
    <div class="col-6 col-md-3"><div class="card stat-card"><div class="card-body d-flex align-items-center gap-3"><i class="bi bi-exclamation-triangle fs-2 text-danger"></i><div><div class="stat-value">@Model.OverdueTaskCount</div><div class="stat-label">Geciken Görev</div></div></div></div></div>
    <div class="col-6 col-md-3"><div class="card stat-card"><div class="card-body d-flex align-items-center gap-3"><i class="bi bi-check2-circle fs-2 text-success"></i><div><div class="stat-value">@Model.CompletedTaskCount</div><div class="stat-label">Tamamlanan Görev</div></div></div></div></div>
    <div class="col-6 col-md-3"><div class="card stat-card"><div class="card-body d-flex align-items-center gap-3"><i class="bi bi-person-check fs-2 text-info"></i><div><div class="stat-value">@Model.AssignedInternCount</div><div class="stat-label">Projeye Atanan</div></div></div></div></div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header bg-white fw-semibold">Son Aktivite</div>
            <div class="card-body p-0">
                @if (Model.RecentActivity.Count == 0)
                {
                    <div class="empty-state py-4"><p class="mb-0">Henüz aktivite yok.</p></div>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                    @foreach (var a in Model.RecentActivity)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-start">
                            <div>
                                <div class="fw-semibold">@a.Title</div>
                                <div class="small text-muted">@a.Detail</div>
                            </div>
                            <span class="small text-muted">@tz.ToLocal(a.AtUtc).ToString("dd.MM.yyyy HH:mm")</span>
                        </li>
                    }
                    </ul>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="d-flex gap-2 flex-wrap">
            <a asp-controller="Interns" asp-action="Index" class="btn btn-outline-primary">Stajyerler</a>
            <a asp-controller="Projects" asp-action="Index" class="btn btn-outline-primary">Projeler</a>
            <a asp-controller="DailyReports" asp-action="Index" class="btn btn-outline-primary">Günlük Raporlar</a>
            <a asp-controller="Messages" asp-action="Inbox" class="btn btn-outline-primary">Mesajlar</a>
            <a asp-controller="LeaveRequests" asp-action="Index" class="btn btn-outline-warning">İzin Talepleri</a>
            <a asp-controller="Transfers" asp-action="Index" class="btn btn-outline-danger">Transferler</a>
        </div>
    </div>
</div>
