@model Staj360.Web.Areas.Manager.Models.CreateTransferViewModel
@{
    ViewData["Title"] = "Yeni Transfer";
}
<h1 class="h4 mb-3">Transfer Talebi / Uygulama</h1>
<div class="card"><div class="card-body">
    <form asp-action="Create" method="post" id="transferCreateForm">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
        <div class="mb-3">
            <label asp-for="InternProfileId" class="form-label"></label>
            <select asp-for="InternProfileId" asp-items="Model.Interns" class="form-select" id="InternProfileId">
                <option value="">Seçiniz...</option>
            </select>
            <span asp-validation-for="InternProfileId" class="text-danger small"></span>
        </div>
        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label asp-for="SourceDirectorateName" class="form-label"></label>
                <input asp-for="SourceDirectorateName" class="form-control" readonly />
            </div>
            <div class="col-md-6">
                <label asp-for="SourceBranchName" class="form-label"></label>
                <input asp-for="SourceBranchName" class="form-control" readonly />
            </div>
        </div>
        <div class="mb-3">
            <label asp-for="TargetDirectorateId" class="form-label"></label>
            <select asp-for="TargetDirectorateId" asp-items="Model.Directorates" class="form-select" id="TargetDirectorateId">
                <option value="">Seçiniz...</option>
            </select>
            <span asp-validation-for="TargetDirectorateId" class="text-danger small"></span>
            <div class="form-text text-muted" id="directorateHint">Önce hedef daire başkanlığını seçiniz.</div>
        </div>
        <div class="mb-3">
            <label asp-for="TargetOrganizationUnitId" class="form-label"></label>
            <select asp-for="TargetOrganizationUnitId" asp-items="Model.Branches" class="form-select" id="TargetOrganizationUnitId"
                    disabled="@(Model.TargetDirectorateId == Guid.Empty ? "disabled" : null)">
                <option value="">Seçiniz...</option>
            </select>
            <span asp-validation-for="TargetOrganizationUnitId" class="text-danger small"></span>
            <div class="form-text text-danger small" id="branchMessage" hidden></div>
        </div>
        <div class="mb-3">
            <label asp-for="TargetAdvisorUserId" class="form-label"></label>
            <select asp-for="TargetAdvisorUserId" asp-items="Model.Advisors" class="form-select" id="TargetAdvisorUserId"
                    disabled="@(Model.TargetOrganizationUnitId == Guid.Empty ? "disabled" : null)">
                <option value="">Seçiniz...</option>
            </select>
            <div class="form-text text-danger small" id="advisorMessage" hidden></div>
        </div>
        <div class="mb-3" style="max-width:240px">
            <label asp-for="PlannedStartDate" class="form-label"></label>
            <input asp-for="PlannedStartDate" type="date" class="form-control" />
        </div>
        <div class="form-check mb-3">
            <input asp-for="ExecuteImmediatelyIfSameManager" class="form-check-input" />
            <label asp-for="ExecuteImmediatelyIfSameManager" class="form-check-label"></label>
        </div>
        <div class="mb-3">
            <label asp-for="RequestNote" class="form-label"></label>
            <textarea asp-for="RequestNote" class="form-control" rows="2"></textarea>
        </div>
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Kaydet</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Vazgeç</a>
    </form>
</div></div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
<script>
(function () {
    var branchesUrl = '@Url.Action("BranchesForDirectorate", "Transfers", new { area = "Manager" })';
    var advisorsUrl = '@Url.Action("AdvisorsForBranch", "Transfers", new { area = "Manager" })';
    var internMeta = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        ViewBag.InternSourceMeta ?? new Dictionary<string, object>(),
        new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));

    var directorate = document.getElementById('TargetDirectorateId');
    var branch = document.getElementById('TargetOrganizationUnitId');
    var advisor = document.getElementById('TargetAdvisorUserId');
    var branchMsg = document.getElementById('branchMessage');
    var advisorMsg = document.getElementById('advisorMessage');
    var internSelect = document.getElementById('InternProfileId');
    var sourceDir = document.getElementById('SourceDirectorateName');
    var sourceBranch = document.getElementById('SourceBranchName');

    function clearSelect(el, placeholder) {
        el.innerHTML = '';
        var opt = document.createElement('option');
        opt.value = '';
        opt.textContent = placeholder || 'Seçiniz...';
        el.appendChild(opt);
    }

    function setEnabled(el, enabled) {
        el.disabled = !enabled;
    }

    function showMsg(el, text) {
        if (!text) { el.hidden = true; el.textContent = ''; return; }
        el.hidden = false;
        el.textContent = text;
    }

    function applyInternSource() {
        var meta = internMeta[internSelect.value];
        if (!meta) {
            sourceDir.value = '';
            sourceBranch.value = '';
            return;
        }
        sourceDir.value = meta.directorate || '';
        sourceBranch.value = meta.branch || '';
    }

    internSelect.addEventListener('change', applyInternSource);
    applyInternSource();

    directorate.addEventListener('change', async function () {
        clearSelect(branch);
        clearSelect(advisor);
        setEnabled(advisor, false);
        showMsg(advisorMsg, '');
        var id = this.value;
        if (!id) {
            setEnabled(branch, false);
            showMsg(branchMsg, 'Önce hedef daire başkanlığını seçiniz.');
            return;
        }
        setEnabled(branch, true);
        showMsg(branchMsg, 'Yükleniyor...');
        try {
            var res = await fetch(branchesUrl + '?id=' + encodeURIComponent(id), { headers: { 'Accept': 'application/json' } });
            var data = await res.json();
            clearSelect(branch);
            if (!data.items || data.items.length === 0) {
                showMsg(branchMsg, data.message || 'Bu başkanlığa bağlı aktif müdürlük bulunamadı.');
                setEnabled(branch, false);
                return;
            }
            data.items.forEach(function (item) {
                var opt = document.createElement('option');
                opt.value = item.id;
                opt.textContent = item.name;
                branch.appendChild(opt);
            });
            showMsg(branchMsg, '');
        } catch (e) {
            showMsg(branchMsg, 'Müdürlük listesi alınamadı.');
            setEnabled(branch, false);
        }
    });

    branch.addEventListener('change', async function () {
        clearSelect(advisor);
        var id = this.value;
        if (!id) {
            setEnabled(advisor, false);
            showMsg(advisorMsg, '');
            return;
        }
        setEnabled(advisor, true);
        showMsg(advisorMsg, 'Yükleniyor...');
        try {
            var res = await fetch(advisorsUrl + '?id=' + encodeURIComponent(id), { headers: { 'Accept': 'application/json' } });
            var data = await res.json();
            clearSelect(advisor);
            if (!data.items || data.items.length === 0) {
                showMsg(advisorMsg, data.message || 'Bu müdürlükte aktif danışman bulunamadı.');
                setEnabled(advisor, false);
                return;
            }
            data.items.forEach(function (item) {
                var opt = document.createElement('option');
                opt.value = item.id;
                opt.textContent = item.name;
                advisor.appendChild(opt);
            });
            showMsg(advisorMsg, '');
        } catch (e) {
            showMsg(advisorMsg, 'Danışman listesi alınamadı.');
            setEnabled(advisor, false);
        }
    });

    if (!directorate.value) {
        setEnabled(branch, false);
        setEnabled(advisor, false);
    }
})();
</script>
}
