@model IReadOnlyList<Staj360.Domain.Entities.InternTransferRequest>
@{
    ViewData["Title"] = "Transferler";
    var advisors = ViewBag.Advisors as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">Bekleyen Transferler</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Yeni Transfer</a>
</div>
<div class="card"><div class="card-body p-0">
@if (Model.Count == 0)
{
    <div class="empty-state"><i class="bi bi-arrow-left-right"></i><p>Bekleyen transfer yok.</p></div>
}
else
{
    <table class="table align-middle mb-0">
        <thead><tr><th>Stajyer</th><th>Kaynak</th><th>Hedef</th><th>Not</th><th class="text-end">İşlem</th></tr></thead>
        <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@(t.InternProfile?.StudentNumber ?? "—")</td>
                <td>@(t.SourceOrganizationUnit?.Name ?? "—")</td>
                <td>@(t.TargetOrganizationUnit?.Name ?? "—")</td>
                <td class="text-muted small">@(t.RequestNote ?? "—")</td>
                <td class="text-end" style="min-width:340px">
                    <form asp-action="Decide" method="post" class="d-flex flex-wrap gap-1 justify-content-end">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="transferRequestId" value="@t.Id" />
                        <select name="targetAdvisorUserId" class="form-select form-select-sm" style="max-width:160px">
                            <option value="">Danışman...</option>
                            @foreach (var a in advisors)
                            {
                                <option value="@a.Value">@a.Text</option>
                            }
                        </select>
                        <input name="decisionNote" class="form-control form-control-sm" placeholder="Not" style="max-width:100px" />
                        <button name="approve" value="true" class="btn btn-sm btn-success">Onayla</button>
                        <button name="approve" value="false" class="btn btn-sm btn-danger">Reddet</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
