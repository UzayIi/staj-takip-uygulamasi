@model IReadOnlyList<Staj360.Domain.Entities.Project>
@{
    ViewData["Title"] = "Projeler";
}
<h1 class="h4 mb-3">Birim Projeleri</h1>
<div class="card"><div class="card-body p-0">
@if (Model.Count == 0)
{
    <div class="empty-state"><i class="bi bi-kanban"></i><p>Birimlerinizde proje bulunmuyor.</p></div>
}
else
{
    <div class="table-responsive">
    <table class="table table-hover mb-0 align-middle">
        <thead><tr><th>Proje</th><th>Birim</th><th>Durum</th><th>İlerleme</th><th class="text-end">İşlem</th></tr></thead>
        <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td><a asp-action="Details" asp-route-id="@p.Id" class="fw-semibold text-decoration-none">@p.Name</a></td>
                <td class="text-muted small">@(p.OrganizationUnit?.Name ?? "—")</td>
                <td><span class="badge @DisplayText.BadgeClass(p.Status)">@DisplayText.Of(p.Status)</span></td>
                <td style="min-width:140px"><div class="progress" style="height:16px"><div class="progress-bar" style="width:@(p.ProgressPercentage)%">@p.ProgressPercentage%</div></div></td>
                <td class="text-end"><a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-primary">Yönet</a></td>
            </tr>
        }
        </tbody>
    </table>
    </div>
}
</div></div>
