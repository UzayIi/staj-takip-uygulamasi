@model IReadOnlyList<Staj360.Domain.Entities.LeaveRequest>
@{
    ViewData["Title"] = "İzin Talepleri";
}
<h1 class="h4 mb-3">Onay Bekleyen İzin Talepleri</h1>
<div class="card"><div class="card-body p-0">
@if (Model.Count == 0)
{
    <div class="empty-state"><i class="bi bi-calendar-x"></i><p>Onay bekleyen izin talebi yok.</p></div>
}
else
{
    <table class="table mb-0 align-middle">
        <thead><tr><th>Stajyer</th><th>Birim</th><th>Tür</th><th>Tarih</th><th>Açıklama</th><th class="text-end">İşlem</th></tr></thead>
        <tbody>
        @foreach (var l in Model)
        {
            <tr>
                <td>@l.InternshipPeriod?.InternProfile?.StudentNumber</td>
                <td>@(l.OrganizationUnit?.Name ?? "—")</td>
                <td>@DisplayText.Of(l.LeaveType)</td>
                <td>@l.StartDate.ToString("dd.MM.yyyy") - @l.EndDate.ToString("dd.MM.yyyy")</td>
                <td class="text-muted">@l.Reason</td>
                <td class="text-end" style="min-width:280px">
                    <form asp-action="Review" method="post" class="d-flex gap-1 justify-content-end">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="leaveRequestId" value="@l.Id" />
                        <input name="reviewerNote" class="form-control form-control-sm" placeholder="Not" style="max-width:140px" />
                        <button name="approve" value="true" class="btn btn-sm btn-success"><i class="bi bi-check-lg"></i></button>
                        <button name="approve" value="false" class="btn btn-sm btn-danger"><i class="bi bi-x-lg"></i></button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
