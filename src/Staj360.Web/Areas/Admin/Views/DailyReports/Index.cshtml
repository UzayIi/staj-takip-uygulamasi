@model IReadOnlyList<Staj360.Domain.Entities.DailyReport>
@{
    ViewData["Title"] = "Günlük Raporlar";
    var status = ViewData["Status"] as DailyReportStatus?;
    var page = (int)ViewData["Page"]!;
    var totalPages = (int)ViewData["TotalPages"]!;
    var search = ViewData["Search"] as string;
    var names = ViewBag.InternNames as IDictionary<Guid, string> ?? new Dictionary<Guid, string>();
}
<h1 class="h4 mb-3">Günlük Raporlar</h1>
<form method="get" class="mb-3 d-flex gap-2 flex-wrap">
    <input type="hidden" name="status" value="@((int?)status)" />
    <input type="text" name="search" value="@search" class="form-control" style="max-width:280px"
           placeholder="Ad soyad veya öğrenci no..." />
    <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
</form>
<div class="btn-group mb-3">
    <a asp-action="Index" asp-route-search="@search" class="btn btn-sm @(status == null ? "btn-primary" : "btn-outline-primary")">Tümü</a>
    <a asp-action="Index" asp-route-status="@((int)DailyReportStatus.Submitted)" asp-route-search="@search" class="btn btn-sm @(status == DailyReportStatus.Submitted ? "btn-primary" : "btn-outline-primary")">Bekleyen</a>
    <a asp-action="Index" asp-route-status="@((int)DailyReportStatus.Approved)" asp-route-search="@search" class="btn btn-sm @(status == DailyReportStatus.Approved ? "btn-primary" : "btn-outline-primary")">Onaylanan</a>
</div>
<div class="card"><div class="card-body p-0">
@if (Model.Count == 0)
{
    <div class="empty-state"><i class="bi bi-journal-text"></i><p>Rapor bulunmuyor.</p></div>
}
else
{
    <table class="table table-hover mb-0 align-middle">
        <thead><tr><th>Stajyer</th><th>Tarih</th><th>Durum</th><th class="text-end">İşlem</th></tr></thead>
        <tbody>
        @foreach (var r in Model)
        {
            var uid = r.InternshipPeriod?.InternProfile?.UserId;
            var fullName = uid.HasValue && names.TryGetValue(uid.Value, out var n) && !string.IsNullOrWhiteSpace(n)
                ? n
                : (r.InternshipPeriod?.InternProfile?.StudentNumber ?? "—");
            <tr>
                <td>@fullName</td>
                <td>@r.ReportDate.ToString("dd.MM.yyyy")</td>
                <td><span class="badge @DisplayText.BadgeClass(r.Status)">@DisplayText.Of(r.Status)</span></td>
                <td class="text-end"><a asp-action="Details" asp-route-id="@r.Id" class="btn btn-sm btn-outline-secondary">Görüntüle</a></td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
@if (totalPages > 1)
{
    <nav class="mt-3"><ul class="pagination">
        @for (int i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == page ? "active" : "")"><a class="page-link" asp-action="Index" asp-route-status="@((int?)status)" asp-route-search="@search" asp-route-page="@i">@i</a></li>
        }
    </ul></nav>
}
