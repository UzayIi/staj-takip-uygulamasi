@model IReadOnlyList<Staj360.Domain.Entities.InternFeedback>
@{
    ViewData["Title"] = "Geri Bildirimler";
}
<h1 class="h4 mb-3">Geri Bildirimler</h1>
<div class="card"><div class="card-body p-0">
@if (Model.Count == 0)
{
    <div class="empty-state"><i class="bi bi-chat-left-text"></i><p>Geri bildirim bulunmuyor.</p></div>
}
else
{
    <table class="table table-hover mb-0 align-middle">
        <thead><tr><th>Stajyer</th><th>Başlık</th><th>Durum</th><th>Tarih</th><th>Cevap</th></tr></thead>
        <tbody>
        @foreach (var f in Model)
        {
            <tr>
                <td>@(f.InternProfile?.StudentNumber ?? "—")</td>
                <td>
                    <div class="fw-semibold">@f.Title</div>
                    <div class="text-muted small">@f.Message</div>
                </td>
                <td><span class="badge bg-secondary">@f.Status</span></td>
                <td>@f.CreatedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                <td class="text-muted small">@(f.ReplyMessage ?? "—")</td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
