@model IReadOnlyList<Staj360.Application.Services.Accounts.AccountSummary>
@{
    ViewData["Title"] = "Danışmanlar";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">Danışmanlar</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-person-plus"></i> Yeni Danışman</a>
</div>
<div class="card"><div class="card-body p-0">
@if (Model.Count == 0)
{
    <div class="empty-state"><i class="bi bi-person-badge"></i><p>Kayıtlı danışman bulunmuyor.</p></div>
}
else
{
    <table class="table table-hover mb-0 align-middle">
        <thead><tr><th>Ad Soyad</th><th>E-posta</th><th>Durum</th><th class="text-end">İşlemler</th></tr></thead>
        <tbody>
        @foreach (var m in Model)
        {
            <tr>
                <td>@m.FullName</td>
                <td class="text-muted">@m.Email</td>
                <td>@if (m.IsActive) { <span class="badge bg-success">Aktif</span> } else { <span class="badge bg-secondary">Pasif</span> }</td>
                <td class="text-end">
                    <form asp-action="SetActive" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@m.UserId" />
                        <input type="hidden" name="isActive" value="@((!m.IsActive).ToString().ToLower())" />
                        <button type="submit" class="btn btn-sm btn-outline-secondary">@(m.IsActive ? "Pasife Al" : "Aktifleştir")</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
