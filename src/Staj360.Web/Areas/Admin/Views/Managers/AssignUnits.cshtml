@model Staj360.Web.Areas.Admin.Models.AssignUnitsViewModel
@{
    ViewData["Title"] = "Birim Atama";
}
<h1 class="h4 mb-3">Birim Atama — @Model.FullName</h1>
<p class="text-muted">@Model.Email</p>

<div class="card mb-3"><div class="card-body">
    <form asp-action="AssignUnit" method="post" class="row g-2 align-items-end">
        @Html.AntiForgeryToken()
        <input type="hidden" name="userId" value="@Model.UserId" />
        <div class="col-md-8">
            <label class="form-label">Şube müdürlüğü</label>
            <select name="organizationUnitId" class="form-select" required>
                <option value="">Seçiniz...</option>
                @foreach (var b in Model.Branches)
                {
                    if (!Model.AssignedUnitIds.Contains(Guid.Parse(b.Value!)))
                    {
                        <option value="@b.Value">@b.Text</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-4">
            <button type="submit" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Ata</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Geri</a>
        </div>
    </form>
</div></div>

<div class="card"><div class="card-header bg-white fw-semibold">Atanmış Birimler</div>
<div class="card-body p-0">
@if (Model.AssignedUnitIds.Count == 0)
{
    <div class="empty-state"><i class="bi bi-diagram-3"></i><p>Henüz birim atanmamış.</p></div>
}
else
{
    <table class="table mb-0 align-middle">
        <thead><tr><th>Birim</th><th class="text-end">İşlem</th></tr></thead>
        <tbody>
        @foreach (var b in Model.Branches.Where(x => Model.AssignedUnitIds.Contains(Guid.Parse(x.Value!))))
        {
            <tr>
                <td>@b.Text</td>
                <td class="text-end">
                    <form asp-action="UnassignUnit" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@Model.UserId" />
                        <input type="hidden" name="organizationUnitId" value="@b.Value" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Kaldır</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
