@model Staj360.Application.Common.PagedResult<Staj360.Domain.Entities.Project>
@{
    ViewData["Title"] = "Projeler";
    var selectedYear = ViewData["Year"] as int?;
    var years = ViewData["Years"] as IReadOnlyList<int> ?? Array.Empty<int>();
}
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h1 class="h4 mb-0">Projeler</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Yeni Proje</a>
</div>

<form method="get" class="mb-3">
    <div class="d-flex gap-2 flex-wrap align-items-end">
        <div style="max-width:160px">
            <label class="form-label small text-muted mb-0">Yıl</label>
            <select name="year" class="form-select" onchange="this.form.submit()">
                <option value="">Tüm Yıllar</option>
                @foreach (var y in years)
                {
                    <option value="@y" selected="@(selectedYear == y ? "selected" : null)">@y</option>
                }
            </select>
        </div>
    </div>
</form>

<div class="card"><div class="card-body p-0">
@if (Model.Items.Count == 0)
{
    <div class="empty-state"><i class="bi bi-kanban"></i><p>Henüz proje bulunmuyor.</p></div>
}
else
{
    <div class="table-responsive">
    <table class="table table-hover mb-0 align-middle">
        <thead><tr><th>Proje</th><th>Şube</th><th>Durum</th><th>İlerleme</th></tr></thead>
        <tbody>
        @foreach (var p in Model.Items)
        {
            <tr>
                <td>
                    <a asp-action="Details" asp-route-id="@p.Id" class="fw-semibold text-decoration-none">@p.Name</a>
                </td>
                <td>@(p.OrganizationUnit?.Name ?? "—")</td>
                <td><span class="badge @DisplayText.BadgeClass(p.Status)">@DisplayText.Of(p.Status)</span></td>
                <td style="min-width:140px"><div class="progress" style="height:16px"><div class="progress-bar" style="width:@(p.ProgressPercentage)%">@p.ProgressPercentage%</div></div></td>
            </tr>
        }
        </tbody>
    </table>
    </div>
}
</div></div>
@if (Model.TotalPages > 1)
{
    <nav class="mt-3"><ul class="pagination flex-wrap">
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-year="@selectedYear">@i</a>
            </li>
        }
    </ul></nav>
}
