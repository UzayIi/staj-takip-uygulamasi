@model Staj360.Web.Areas.Admin.Models.CreateInternViewModel
@{
    ViewData["Title"] = "Yeni Stajyer";
    var showConfirm = ViewData["ShowCreateConfirm"] as bool? == true;
}
<h1 class="h4 mb-3">Yeni Stajyer</h1>
<div class="card"><div class="card-body">
    <form asp-action="Create" method="post" id="createInternForm" data-create-confirm="true">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Confirmed" id="Confirmed" value="false" />
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger small"></span>
                <div class="form-text">En az 8 karakter, büyük/küçük harf, rakam ve sembol içermeli.</div>
            </div>
            <div class="col-md-6">
                <label asp-for="StudentNumber" class="form-label"></label>
                <input asp-for="StudentNumber" class="form-control" />
                <span asp-validation-for="StudentNumber" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="OrganizationUnitId" class="form-label"></label>
                <select asp-for="OrganizationUnitId" asp-items="Model.OrganizationUnits" class="form-select" id="OrganizationUnitId"><option value="">Seçiniz...</option></select>
                <span asp-validation-for="OrganizationUnitId" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="AdvisorUserId" class="form-label"></label>
                <select asp-for="AdvisorUserId" asp-items="Model.Advisors" class="form-select" id="AdvisorUserId"><option value="">Seçiniz...</option></select>
                <span asp-validation-for="AdvisorUserId" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="NationalId" class="form-label"></label>
                <input asp-for="NationalId" class="form-control" />
                <div class="form-text">Hassas veri olarak işlenir, maskeli gösterilir.</div>
            </div>
            <div class="col-md-4"><label asp-for="University" class="form-label"></label><input asp-for="University" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="Faculty" class="form-label"></label><input asp-for="Faculty" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="SchoolDepartment" class="form-label"></label><input asp-for="SchoolDepartment" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="ClassLevel" class="form-label"></label><input asp-for="ClassLevel" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="PhoneNumber" class="form-label"></label><input asp-for="PhoneNumber" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="EmergencyContactName" class="form-label"></label><input asp-for="EmergencyContactName" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="EmergencyContactPhone" class="form-label"></label><input asp-for="EmergencyContactPhone" class="form-control" /></div>
            <div class="col-12">
                <label asp-for="Address" class="form-label"></label>
                <textarea asp-for="Address" class="form-control" rows="3" maxlength="500"></textarea>
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>
        </div>
        <div class="mt-3">
            <button type="submit" class="btn btn-primary" id="createInternSubmit"><i class="bi bi-check-lg"></i> Kaydet</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Vazgeç</a>
        </div>
    </form>
</div></div>

<div class="modal fade" id="createConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-plus me-2"></i>Stajyer Ekleme Onayı</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">Aşağıdaki bilgilerle stajyer hesabı oluşturulacak. Onaylıyor musunuz?</p>
                <ul class="list-unstyled mb-0 small">
                    <li><strong>Ad Soyad:</strong> <span id="confirm-fullname"></span></li>
                    <li><strong>E-posta:</strong> <span id="confirm-email"></span></li>
                    <li><strong>Öğrenci No:</strong> <span id="confirm-student"></span></li>
                    <li><strong>Şube:</strong> <span id="confirm-unit"></span></li>
                    <li><strong>Danışman:</strong> <span id="confirm-advisor"></span></li>
                    <li><strong>Üniversite:</strong> <span id="confirm-uni"></span></li>
                </ul>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Vazgeç</button>
                <button type="button" class="btn btn-primary" id="confirmCreateBtn">Onayla ve Ekle</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function () {
        var form = document.getElementById('createInternForm');
        var confirmedInput = document.getElementById('Confirmed');
        var modalEl = document.getElementById('createConfirmModal');
        var modal = new bootstrap.Modal(modalEl);
        var submitting = false;
        var serverShow = @(showConfirm ? "true" : "false");

        function fillConfirm() {
            document.getElementById('confirm-fullname').textContent = form.FullName.value || '-';
            document.getElementById('confirm-email').textContent = form.Email.value || '-';
            document.getElementById('confirm-student').textContent = form.StudentNumber.value || '-';
            var unit = form.OrganizationUnitId;
            document.getElementById('confirm-unit').textContent = unit.options[unit.selectedIndex]?.text || '-';
            var adv = form.AdvisorUserId;
            document.getElementById('confirm-advisor').textContent = adv.options[adv.selectedIndex]?.text || '-';
            document.getElementById('confirm-uni').textContent = form.University.value || '-';
        }

        form.addEventListener('submit', function (e) {
            if (confirmedInput.value === 'true' || confirmedInput.value === 'True') return;
            if (typeof $(form).valid === 'function' && !$(form).valid()) return;
            e.preventDefault();
            fillConfirm();
            modal.show();
        });

        document.getElementById('confirmCreateBtn').addEventListener('click', function () {
            if (submitting) return;
            submitting = true;
            this.disabled = true;
            confirmedInput.value = 'true';
            form.submit();
        });

        if (serverShow) {
            fillConfirm();
            modal.show();
        }
    })();
    </script>
}
