@model Staj360.Application.Common.PagedResult<Staj360.Domain.Entities.InternshipPeriod>
@{
    ViewData["Title"] = "Staj Dönemleri";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">Staj Dönemleri</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Yeni Dönem</a>
</div>
<div class="card"><div class="card-body p-0">
@if (Model.Items.Count == 0)
{
    <div class="empty-state"><i class="bi bi-calendar-range"></i><p>Kayıtlı staj dönemi bulunmuyor.</p></div>
}
else
{
    <table class="table table-hover mb-0 align-middle">
        <thead><tr><th>Stajyer</th><th>Program</th><th>Başlangıç</th><th>Bitiş</th><th>Gerekli Gün</th><th>Durum</th><th class="text-end">İşlemler</th></tr></thead>
        <tbody>
        @foreach (var p in Model.Items)
        {
            var fullName = ViewBag.InternNames != null && ((Dictionary<Guid, string>)ViewBag.InternNames).ContainsKey(p.InternProfileId) 
                ? ((Dictionary<Guid, string>)ViewBag.InternNames)[p.InternProfileId] 
                : p.InternProfile?.StudentNumber;
            <tr>
                <td>@fullName</td>
                <td class="text-muted">@p.WorkSchedule?.Name</td>
                <td>@p.StartDate.ToString("dd.MM.yyyy")</td>
                <td>@p.EndDate.ToString("dd.MM.yyyy")</td>
                <td>@p.RequiredWorkDays</td>
                <td><span class="badge bg-secondary">@DisplayText.Of(p.Status)</span></td>
                <td class="text-end">
                    @if (p.Status == InternshipStatus.Pending)
                    {
                        <form asp-action="Activate" asp-route-id="@p.Id" method="post" class="d-inline">
                            <button class="btn btn-sm btn-outline-success">Aktifleştir</button>
                        </form>
                    }
                    else if (p.Status == InternshipStatus.Active)
                    {
                        <form asp-action="Complete" asp-route-id="@p.Id" method="post" class="d-inline" data-confirm="Dönemi tamamlandı olarak işaretlemek istiyor musunuz?">
                            <button class="btn btn-sm btn-outline-secondary">Tamamla</button>
                        </form>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
@if (Model.TotalPages > 1)
{
    <nav class="mt-3"><ul class="pagination">
        @for (int p = 1; p <= Model.TotalPages; p++)
        {
            <li class="page-item @(p == Model.Page ? "active" : "")"><a class="page-link" asp-action="Index" asp-route-page="@p">@p</a></li>
        }
    </ul></nav>
}
