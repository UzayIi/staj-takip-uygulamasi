@model IReadOnlyList<Staj360.Domain.Entities.LeaveRequest>
@{
    ViewData["Title"] = "İzin Talepleri";
}
<h1 class="h4 mb-3">Bekleyen İzin Talepleri</h1>
<p class="text-muted small mb-3">İzin onayları ilgili birimin yöneticileri tarafından yapılır. Bu ekran yalnızca görüntülemedir.</p>
<div class="card"><div class="card-body p-0">
@if (Model.Count == 0)
{
    <div class="empty-state"><i class="bi bi-calendar-x"></i><p>Onay bekleyen izin talebi yok.</p></div>
}
else
{
    <table class="table mb-0 align-middle">
        <thead><tr><th>Stajyer</th><th>Birim</th><th>Tür</th><th>Tarih</th><th>Açıklama</th><th>Durum</th></tr></thead>
        <tbody>
        @foreach (var l in Model)
        {
            <tr>
                <td>@l.InternshipPeriod?.InternProfile?.StudentNumber</td>
                <td>@(l.OrganizationUnit?.Name ?? "—")</td>
                <td>@DisplayText.Of(l.LeaveType)</td>
                <td>@l.StartDate.ToString("dd.MM.yyyy") - @l.EndDate.ToString("dd.MM.yyyy")</td>
                <td class="text-muted">@l.Reason</td>
                <td><span class="badge @DisplayText.BadgeClass(l.Status)">@DisplayText.Of(l.Status)</span></td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
