@model IReadOnlyList<Staj360.Domain.Entities.InternTransferRequest>
@{
    ViewData["Title"] = "Transferler";
}
<h1 class="h4 mb-3">Stajyer Transferleri (Salt Okunur)</h1>
<div class="card"><div class="card-body p-0">
@if (Model.Count == 0)
{
    <div class="empty-state"><i class="bi bi-arrow-left-right"></i><p>Transfer kaydı bulunmuyor.</p></div>
}
else
{
    <table class="table table-hover mb-0 align-middle">
        <thead><tr><th>Stajyer</th><th>Kaynak</th><th>Hedef</th><th>Durum</th><th>Tarih</th><th></th></tr></thead>
        <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@(t.InternProfile?.StudentNumber ?? "—")</td>
                <td>@(t.SourceOrganizationUnit?.Name ?? "—")</td>
                <td>@(t.TargetOrganizationUnit?.Name ?? "—")</td>
                <td><span class="badge bg-secondary">@t.Status</span></td>
                <td>@t.CreatedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                <td class="text-end"><a asp-action="Details" asp-route-id="@t.Id" class="btn btn-sm btn-outline-primary">Detay</a></td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
