@model Staj360.Web.Areas.Admin.Models.DepartmentViewModel
@{
    ViewData["Title"] = "Departman Düzenle";
}
<h1 class="h4 mb-3">Departman Düzenle</h1>
<div class="card"><div class="card-body">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
        <partial name="_DepartmentForm" model="Model" />
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Güncelle</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Vazgeç</a>
    </form>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
