@model IReadOnlyList<Staj360.Domain.Entities.AuditLog>
@{
    ViewData["Title"] = "Denetim Kayıtları";
    var page = (int)ViewData["Page"]!;
    var totalPages = (int)ViewData["TotalPages"]!;
    var tz = (Staj360.Application.Abstractions.ITimeZoneService)Context.RequestServices.GetService(typeof(Staj360.Application.Abstractions.ITimeZoneService))!;
}
<h1 class="h4 mb-3">Denetim Kayıtları</h1>
<div class="card"><div class="card-body p-0">
@if (Model.Count == 0)
{
    <div class="empty-state"><i class="bi bi-shield-check"></i><p>Kayıt bulunmuyor.</p></div>
}
else
{
    <table class="table table-hover mb-0 align-middle">
        <thead><tr><th>Tarih</th><th>İşlem</th><th>Varlık</th><th>Varlık Id</th><th>IP</th></tr></thead>
        <tbody>
        @foreach (var a in Model)
        {
            <tr>
                <td>@tz.ToLocal(a.CreatedAtUtc).ToString("dd.MM.yyyy HH:mm")</td>
                <td><span class="badge bg-secondary">@a.Action</span></td>
                <td>@a.EntityName</td>
                <td class="text-muted small">@a.EntityId</td>
                <td class="text-muted small">@a.IpAddress</td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
@if (totalPages > 1)
{
    <nav class="mt-3"><ul class="pagination">
        @for (int i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == page ? "active" : "")"><a class="page-link" asp-action="Index" asp-route-page="@i">@i</a></li>
        }
    </ul></nav>
}
