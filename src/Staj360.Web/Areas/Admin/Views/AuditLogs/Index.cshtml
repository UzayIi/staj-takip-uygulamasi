@model Staj360.Web.Areas.Admin.Models.AuditLogFilterViewModel
@{
    ViewData["Title"] = "Kullanıcı Hareketleri";
    var tz = (Staj360.Application.Abstractions.ITimeZoneService)Context.RequestServices.GetService(typeof(Staj360.Application.Abstractions.ITimeZoneService))!;
    var units = ViewBag.Units as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}
<h1 class="h4 mb-3">Kullanıcı Hareketleri</h1>

<form method="get" class="card mb-3"><div class="card-body">
    <div class="row g-2">
        <div class="col-md-2"><label class="form-label small">Kullanıcı Id</label><input name="UserId" value="@Model.UserId" class="form-control form-control-sm" /></div>
        <div class="col-md-2"><label class="form-label small">Rol</label><input name="Role" value="@Model.Role" class="form-control form-control-sm" placeholder="Manager" /></div>
        <div class="col-md-2"><label class="form-label small">İşlem</label><input name="Action" value="@Model.Action" class="form-control form-control-sm" /></div>
        <div class="col-md-2">
            <label class="form-label small">Birim</label>
            <select name="OrganizationUnitId" class="form-select form-select-sm">
                <option value="">Tümü</option>
                @foreach (var u in units)
                {
                    if (Model.OrganizationUnitId == (Guid)u.Id)
                    {
                        <option value="@u.Id" selected>@u.Name</option>
                    }
                    else
                    {
                        <option value="@u.Id">@u.Name</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2"><label class="form-label small">Başlangıç (UTC)</label><input type="datetime-local" name="FromUtc" value="@(Model.FromUtc?.ToString("yyyy-MM-ddTHH:mm"))" class="form-control form-control-sm" /></div>
        <div class="col-md-2"><label class="form-label small">Bitiş (UTC)</label><input type="datetime-local" name="ToUtc" value="@(Model.ToUtc?.ToString("yyyy-MM-ddTHH:mm"))" class="form-control form-control-sm" /></div>
        <div class="col-md-2"><label class="form-label small">IP</label><input name="IpAddress" value="@Model.IpAddress" class="form-control form-control-sm" /></div>
        <div class="col-md-2">
            <label class="form-label small">Başarı</label>
            <select name="IsSuccessful" class="form-select form-select-sm">
                <option value="">Tümü</option>
                <option value="true" selected="@(Model.IsSuccessful == true)">Başarılı</option>
                <option value="false" selected="@(Model.IsSuccessful == false)">Başarısız</option>
            </select>
        </div>
        <div class="col-md-4"><label class="form-label small">Ara</label><input name="Search" value="@Model.Search" class="form-control form-control-sm" placeholder="Açıklama, aktör, varlık…" /></div>
        <div class="col-md-2 d-flex align-items-end"><button class="btn btn-sm btn-primary w-100" type="submit">Filtrele</button></div>
    </div>
</div></form>

<div class="card"><div class="card-body p-0">
@if (Model.Items.Count == 0)
{
    <div class="empty-state"><i class="bi bi-shield-check"></i><p>Kayıt bulunmuyor.</p></div>
}
else
{
    <table class="table table-hover mb-0 align-middle">
        <thead><tr><th>Tarih</th><th>Aktör</th><th>Rol</th><th>İşlem</th><th>Varlık</th><th>Başarı</th><th>IP</th><th></th></tr></thead>
        <tbody>
        @foreach (var a in Model.Items)
        {
            <tr>
                <td class="small">@tz.ToLocal(a.CreatedAtUtc).ToString("dd.MM.yyyy HH:mm")</td>
                <td>@(a.ActorNameSnapshot ?? "—")</td>
                <td class="small text-muted">@(a.ActorRoleSnapshot ?? "—")</td>
                <td><span class="badge bg-secondary">@a.Action</span></td>
                <td class="small">@a.EntityName <span class="text-muted">@a.EntityId</span></td>
                <td>@(a.IsSuccessful ? Html.Raw("<span class=\"badge bg-success\">Evet</span>") : Html.Raw("<span class=\"badge bg-danger\">Hayır</span>"))</td>
                <td class="text-muted small">@a.IpAddress</td>
                <td class="text-end"><a asp-action="Details" asp-route-id="@a.Id" class="btn btn-sm btn-outline-primary">Detay</a></td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3"><ul class="pagination flex-wrap">
        @for (int i = 1; i <= Model.TotalPages && i <= 40; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@i"
                   asp-route-UserId="@Model.UserId"
                   asp-route-Role="@Model.Role"
                   asp-route-Action="@Model.Action"
                   asp-route-OrganizationUnitId="@Model.OrganizationUnitId"
                   asp-route-FromUtc="@Model.FromUtc"
                   asp-route-ToUtc="@Model.ToUtc"
                   asp-route-IpAddress="@Model.IpAddress"
                   asp-route-IsSuccessful="@Model.IsSuccessful"
                   asp-route-Search="@Model.Search">@i</a>
            </li>
        }
    </ul></nav>
}
<p class="text-muted small mt-2">Toplam @Model.TotalCount kayıt · Salt okunur (düzenleme/silme yok).</p>
