@model IReadOnlyList<Staj360.Domain.Entities.DailyReport>
@{
    ViewData["Title"] = "Günlük Raporlarım";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">Günlük Raporlarım</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Yeni Rapor</a>
</div>
<div class="card"><div class="card-body p-0">
@if (Model.Count == 0)
{
    <div class="empty-state"><i class="bi bi-journal-text"></i><p>Henüz rapor oluşturmadınız.</p></div>
}
else
{
    <table class="table table-hover mb-0 align-middle">
        <thead><tr><th>Tarih</th><th>Çalışma Kalemi</th><th>Durum</th><th class="text-end">İşlem</th></tr></thead>
        <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@r.ReportDate.ToString("dd.MM.yyyy")</td>
                <td>@r.WorkItems.Count</td>
                <td><span class="badge @DisplayText.BadgeClass(r.Status)">@DisplayText.Of(r.Status)</span></td>
                <td class="text-end"><a asp-action="Details" asp-route-id="@r.Id" class="btn btn-sm btn-outline-secondary">Detay</a></td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
