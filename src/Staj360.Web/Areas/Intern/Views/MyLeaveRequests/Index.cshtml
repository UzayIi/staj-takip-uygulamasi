@model IReadOnlyList<Staj360.Domain.Entities.LeaveRequest>
@{
    ViewData["Title"] = "İzinlerim";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">İzinlerim</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Yeni İzin Talebi</a>
</div>
<div class="card"><div class="card-body p-0">
@if (Model.Count == 0)
{
    <div class="empty-state"><i class="bi bi-calendar-x"></i><p>İzin talebiniz bulunmuyor.</p></div>
}
else
{
    <table class="table table-hover mb-0 align-middle">
        <thead><tr><th>Tür</th><th>Başlangıç</th><th>Bitiş</th><th>Açıklama</th><th>Durum</th></tr></thead>
        <tbody>
        @foreach (var l in Model)
        {
            <tr>
                <td>@DisplayText.Of(l.LeaveType)</td>
                <td>@l.StartDate.ToString("dd.MM.yyyy")</td>
                <td>@l.EndDate.ToString("dd.MM.yyyy")</td>
                <td class="text-muted">@l.Reason</td>
                <td><span class="badge @DisplayText.BadgeClass(l.Status)">@DisplayText.Of(l.Status)</span></td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
