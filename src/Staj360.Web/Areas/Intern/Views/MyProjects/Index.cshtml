@model IReadOnlyList<Staj360.Domain.Entities.Project>
@{
    ViewData["Title"] = "Projelerim";
}
<h1 class="h4 mb-3">Projelerim</h1>
<div class="card"><div class="card-body p-0">
@if (Model.Count == 0)
{
    <div class="empty-state"><i class="bi bi-kanban"></i><p>Atandığınız proje bulunmuyor.</p></div>
}
else
{
    <table class="table table-hover mb-0 align-middle">
        <thead><tr><th>Proje</th><th>Durum</th><th>İlerleme</th><th>Başlangıç</th></tr></thead>
        <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Name<div class="text-muted small">@p.Description</div></td>
                <td><span class="badge @DisplayText.BadgeClass(p.Status)">@DisplayText.Of(p.Status)</span></td>
                <td style="min-width:140px">
                    <div class="progress" style="height:16px"><div class="progress-bar" style="width:@(p.ProgressPercentage)%">@p.ProgressPercentage%</div></div>
                </td>
                <td>@p.StartDate.ToString("dd.MM.yyyy")</td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
