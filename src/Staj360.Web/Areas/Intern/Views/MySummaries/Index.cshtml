@model IReadOnlyList<Staj360.Domain.Entities.AiReportSummary>
@{
    ViewData["Title"] = "Özetlerim";
}
<h1 class="h4 mb-3">Özetlerim</h1>
<div class="card"><div class="card-body p-0">
@if (Model.Count == 0)
{
    <div class="empty-state"><i class="bi bi-robot"></i><p>Sizin için oluşturulmuş özet bulunmuyor.</p></div>
}
else
{
    <table class="table table-hover mb-0 align-middle">
        <thead><tr><th>Tür</th><th>Dönem</th><th>Durum</th><th class="text-end">İşlem</th></tr></thead>
        <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@DisplayText.Of(s.SummaryType)</td>
                <td>@s.PeriodStart.ToString("dd.MM.yyyy") - @s.PeriodEnd.ToString("dd.MM.yyyy")</td>
                <td><span class="badge bg-secondary">@DisplayText.Of(s.Status)</span></td>
                <td class="text-end"><a asp-action="Details" asp-route-id="@s.Id" class="btn btn-sm btn-outline-secondary">Görüntüle</a></td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
