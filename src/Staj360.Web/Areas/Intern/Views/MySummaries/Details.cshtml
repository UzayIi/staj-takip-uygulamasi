@model Staj360.Web.Models.AiReportSummaryViewModel
@{
    ViewData["Title"] = "Özet Detayı";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">@DisplayText.Of(Model.SummaryType) - @Model.PeriodStart.ToString("dd.MM.yyyy") / @Model.PeriodEnd.ToString("dd.MM.yyyy")</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Listeye Dön</a>
</div>
<partial name="_AiSummaryDetails" model="Model" />
