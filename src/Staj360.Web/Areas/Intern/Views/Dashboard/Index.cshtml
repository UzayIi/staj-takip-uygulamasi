@model Staj360.Web.Areas.Intern.Models.InternDashboardViewModel
@{
    ViewData["Title"] = "Stajyer Paneli";
}
<h1 class="h4 mb-4">Stajyer Paneli</h1>

@if (!Model.HasActivePeriod)
{
    <div class="alert alert-info"><i class="bi bi-info-circle"></i> Aktif bir staj döneminiz bulunmuyor. Lütfen yöneticinizle iletişime geçin.</div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-6 col-lg-4">
            <div class="card h-100"><div class="card-body">
                <h6 class="text-muted">Bugünkü Devam Durumu</h6>
                @{
                    var t = Model.Today;
                    var open = t?.HasOpenCheckIn ?? false;
                }
                <p class="mb-1">
                    <strong>Giriş:</strong> @(t?.FirstCheckInLocal?.ToString("HH:mm") ?? "-")
                    &nbsp; <strong>Çıkış:</strong> @(t?.LastCheckOutLocal?.ToString("HH:mm") ?? "-")
                </p>
                <p class="mb-1"><strong>Toplam:</strong> @((t?.TotalWorkedMinutes ?? 0) / 60) sa @((t?.TotalWorkedMinutes ?? 0) % 60) dk</p>
                @if (t is not null && t.IsLate) { <span class="badge bg-warning text-dark">Geç Kalındı</span> }
                <div class="mt-3 d-flex gap-2">
                    @if (!open)
                    {
                        <form asp-action="CheckIn" method="post"><button class="btn btn-success"><i class="bi bi-box-arrow-in-right"></i> Giriş Yap</button></form>
                    }
                    else
                    {
                        <form asp-action="CheckOut" method="post"><button class="btn btn-danger"><i class="bi bi-box-arrow-right"></i> Çıkış Yap</button></form>
                    }
                </div>
            </div></div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card h-100"><div class="card-body">
                <h6 class="text-muted">Günlük Rapor</h6>
                @if (Model.HasTodayReport && Model.TodayReportStatus is not null)
                {
                    <span class="badge @DisplayText.BadgeClass(Model.TodayReportStatus.Value)">@DisplayText.Of(Model.TodayReportStatus.Value)</span>
                }
                else
                {
                    <p class="text-muted mb-2">Bugün için henüz rapor oluşturmadınız.</p>
                    <a asp-controller="MyDailyReports" asp-action="Create" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg"></i> Rapor Oluştur</a>
                }
            </div></div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card h-100"><div class="card-body">
                <h6 class="text-muted">Özet</h6>
                <p class="mb-1"><strong>Kalan Staj Günü:</strong> @Model.RemainingDays</p>
                <p class="mb-0"><strong>Aktif Görev:</strong> @Model.ActiveTaskCount</p>
            </div></div>
        </div>
    </div>
}
