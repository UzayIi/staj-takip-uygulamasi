@model IReadOnlyList<Staj360.Domain.Entities.ProjectTask>
@{
    ViewData["Title"] = "Görevlerim";
}
<h1 class="h4 mb-3">Görevlerim</h1>
<div class="card"><div class="card-body p-0">
@if (Model.Count == 0)
{
    <div class="empty-state"><i class="bi bi-list-check"></i><p>Size atanmış görev bulunmuyor.</p></div>
}
else
{
    <table class="table table-hover mb-0 align-middle">
        <thead><tr><th>Görev</th><th>Proje</th><th>Öncelik</th><th>Bitiş</th><th>Durum</th><th class="text-end">Güncelle</th></tr></thead>
        <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@t.Title<div class="text-muted small">@t.Description</div></td>
                <td>@t.Project?.Name</td>
                <td>@DisplayText.Of(t.Priority)</td>
                <td>@(t.DueDate?.ToString("dd.MM.yyyy") ?? "-")</td>
                <td><span class="badge @DisplayText.BadgeClass(t.Status)">@DisplayText.Of(t.Status)</span></td>
                <td class="text-end">
                    <form asp-action="UpdateStatus" method="post" class="d-inline-flex gap-1">
                        <input type="hidden" name="taskId" value="@t.Id" />
                        <select name="status" class="form-select form-select-sm" style="width:auto">
                            <option value="0" selected="@(t.Status == ProjectTaskStatus.Todo)">Yapılacak</option>
                            <option value="1" selected="@(t.Status == ProjectTaskStatus.InProgress)">Devam Ediyor</option>
                            <option value="2" selected="@(t.Status == ProjectTaskStatus.InReview)">İncelemede</option>
                            <option value="3" selected="@(t.Status == ProjectTaskStatus.Done)">Tamamlandı</option>
                        </select>
                        <button class="btn btn-sm btn-outline-primary"><i class="bi bi-check-lg"></i></button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
