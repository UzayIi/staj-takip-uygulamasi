@model IReadOnlyList<Staj360.Domain.Entities.AttendanceDay>
@{
    ViewData["Title"] = "Devam Durumum";
    var tz = (Staj360.Application.Abstractions.ITimeZoneService)Context.RequestServices.GetService(typeof(Staj360.Application.Abstractions.ITimeZoneService))!;
}
<h1 class="h4 mb-3">Devam Durumum</h1>
<div class="card"><div class="card-body p-0">
@if (Model.Count == 0)
{
    <div class="empty-state"><i class="bi bi-clock-history"></i><p>Devam kaydı bulunmuyor.</p></div>
}
else
{
    <table class="table table-hover mb-0 align-middle">
        <thead><tr><th>Tarih</th><th>Giriş</th><th>Çıkış</th><th>Süre</th><th>Durum</th><th>İşaretler</th></tr></thead>
        <tbody>
        @foreach (var d in Model)
        {
            <tr>
                <td>@d.WorkDate.ToString("dd.MM.yyyy")</td>
                <td>@(d.FirstCheckInUtc.HasValue ? tz.ToLocal(d.FirstCheckInUtc.Value).ToString("HH:mm") : "-")</td>
                <td>@(d.LastCheckOutUtc.HasValue ? tz.ToLocal(d.LastCheckOutUtc.Value).ToString("HH:mm") : "-")</td>
                <td>@(d.TotalWorkedMinutes / 60)sa @(d.TotalWorkedMinutes % 60)dk</td>
                <td><span class="badge @DisplayText.BadgeClass(d.Status)">@DisplayText.Of(d.Status)</span></td>
                <td>
                    @if (d.IsLate) { <span class="badge bg-warning text-dark">Geç</span> }
                    @if (d.IsEarlyLeave) { <span class="badge bg-warning text-dark">Erken Çıkış</span> }
                    @if (d.IsIncomplete) { <span class="badge bg-danger">Eksik</span> }
                </td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
