@model IReadOnlyList<Staj360.Domain.Entities.AiReportSummary>
@{
    ViewData["Title"] = "Yapay Zekâ Özetleri";
    var aiEnabled = ViewData["AiEnabled"] as bool? ?? false;
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">Yapay Zekâ Özetleri</h1>
    @if (aiEnabled)
    {
        <a asp-action="Generate" class="btn btn-primary"><i class="bi bi-robot"></i> Yeni Özet Oluştur</a>
    }
    else
    {
        <button class="btn btn-secondary" disabled title="Yapay zekâ devre dışı"><i class="bi bi-robot"></i> Yeni Özet Oluştur</button>
    }
</div>

@if (!aiEnabled)
{
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle"></i> Yapay zekâ özeti şu anda devre dışı.</div>
}

<div class="card"><div class="card-body p-0">
@if (Model.Count == 0)
{
    <div class="empty-state"><i class="bi bi-robot"></i><p>Henüz özet oluşturulmadı.</p></div>
}
else
{
    <table class="table table-hover mb-0 align-middle">
        <thead><tr><th>Stajyer</th><th>Tür</th><th>Dönem</th><th>Durum</th><th class="text-end">İşlem</th></tr></thead>
        <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.InternshipPeriod?.InternProfile?.StudentNumber</td>
                <td>@DisplayText.Of(s.SummaryType)</td>
                <td>@s.PeriodStart.ToString("dd.MM.yyyy") - @s.PeriodEnd.ToString("dd.MM.yyyy")</td>
                <td><span class="badge bg-secondary">@DisplayText.Of(s.Status)</span></td>
                <td class="text-end"><a asp-action="Details" asp-route-id="@s.Id" class="btn btn-sm btn-outline-secondary">Görüntüle</a></td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
