@model IReadOnlyList<Staj360.Domain.Entities.InternProfile>
@{
    ViewData["Title"] = "Stajyerlerim";
}
<h1 class="h4 mb-3">Stajyerlerim</h1>
<div class="card"><div class="card-body p-0">
@if (Model.Count == 0)
{
    <div class="empty-state"><i class="bi bi-people"></i><p>Size atanmış stajyer bulunmuyor.</p></div>
}
else
{
    <table class="table table-hover mb-0 align-middle">
        <thead><tr><th>Öğrenci No</th><th>Departman</th><th>Üniversite</th></tr></thead>
        <tbody>
        @foreach (var i in Model)
        {
            <tr><td>@i.StudentNumber</td><td>@i.Department?.Name</td><td class="text-muted">@i.University</td></tr>
        }
        </tbody>
    </table>
}
</div></div>
