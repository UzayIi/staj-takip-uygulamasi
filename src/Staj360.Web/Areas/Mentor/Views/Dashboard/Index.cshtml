@model Staj360.Web.Areas.Mentor.Models.MentorDashboardViewModel
@{
    ViewData["Title"] = "Danışman Paneli";
}
<h1 class="h4 mb-4">Danışman Paneli</h1>
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4"><div class="card stat-card"><div class="card-body d-flex align-items-center gap-3"><i class="bi bi-people fs-2 text-primary"></i><div><div class="stat-value">@Model.InternCount</div><div class="stat-label">Stajyerlerim</div></div></div></div></div>
    <div class="col-6 col-md-4"><div class="card stat-card"><div class="card-body d-flex align-items-center gap-3"><i class="bi bi-journal-text fs-2 text-danger"></i><div><div class="stat-value">@Model.PendingReportCount</div><div class="stat-label">Bekleyen Rapor</div></div></div></div></div>
    <div class="col-6 col-md-4"><div class="card stat-card"><div class="card-body d-flex align-items-center gap-3"><i class="bi bi-calendar-range fs-2 text-success"></i><div><div class="stat-value">@Model.ActivePeriodCount</div><div class="stat-label">Aktif Dönem</div></div></div></div></div>
</div>

<div class="card">
    <div class="card-header bg-white fw-semibold">Onay Bekleyen Son Raporlar</div>
    <div class="card-body p-0">
        @if (Model.RecentReports.Count == 0)
        {
            <div class="empty-state"><i class="bi bi-inbox"></i><p>Bekleyen rapor yok.</p></div>
        }
        else
        {
            <table class="table table-hover mb-0 align-middle">
                <thead><tr><th>Stajyer</th><th>Tarih</th><th class="text-end">İşlem</th></tr></thead>
                <tbody>
                @foreach (var r in Model.RecentReports)
                {
                    <tr>
                        <td>@r.InternshipPeriod?.InternProfile?.StudentNumber</td>
                        <td>@r.ReportDate.ToString("dd.MM.yyyy")</td>
                        <td class="text-end"><a asp-controller="DailyReports" asp-action="Details" asp-route-id="@r.Id" class="btn btn-sm btn-primary">İncele</a></td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>
