@model Staj360.Web.Areas.Mentor.Models.CreateProjectViewModel
@{
    ViewData["Title"] = "Yeni Proje";
}
<h1 class="h4 mb-3">Yeni Proje</h1>
<div class="card"><div class="card-body">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger"></span></div>
        <div class="mb-3"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control" rows="3"></textarea></div>
        <div class="row g-3 mb-3">
            <div class="col-md-6"><label asp-for="StartDate" class="form-label"></label><input asp-for="StartDate" type="date" class="form-control" /></div>
            <div class="col-md-6"><label asp-for="EndDate" class="form-label"></label><input asp-for="EndDate" type="date" class="form-control" /></div>
        </div>
        <div class="mb-3">
            <label asp-for="OrganizationUnitId" class="form-label"></label>
            <select asp-for="OrganizationUnitId" asp-items="Model.OrganizationUnits" class="form-select"><option value="">-- Seçiniz --</option></select>
            <span asp-validation-for="OrganizationUnitId" class="text-danger"></span>
        </div>
        <div class="mb-3"><label asp-for="RepositoryUrl" class="form-label"></label><input asp-for="RepositoryUrl" class="form-control" /></div>
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Kaydet</button>
        <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
    </form>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
