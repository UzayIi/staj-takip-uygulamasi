@model Staj360.Web.Areas.Mentor.Models.CreateEvaluationViewModel
@{
    ViewData["Title"] = "Yeni Değerlendirme";
}
<h1 class="h4 mb-3">Yeni Değerlendirme</h1>
<div class="card"><div class="card-body">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="row g-3 mb-3">
            <div class="col-md-8">
                <label asp-for="InternshipPeriodId" class="form-label"></label>
                <select asp-for="InternshipPeriodId" asp-items="Model.Periods" class="form-select"><option value="">-- Seçiniz --</option></select>
                <span asp-validation-for="InternshipPeriodId" class="text-danger"></span>
            </div>
            <div class="col-md-4"><label asp-for="EvaluationDate" class="form-label"></label><input asp-for="EvaluationDate" type="date" class="form-control" /></div>
        </div>
        <p class="text-muted small">Puanlar 1 (düşük) ile 5 (yüksek) arasındadır.</p>
        <div class="row g-3">
            @{
                (string name, string label)[] scores = new[]
                {
                    (nameof(Model.TechnicalKnowledgeScore), "Teknik Bilgi"),
                    (nameof(Model.ResponsibilityScore), "Sorumluluk"),
                    (nameof(Model.TeamworkScore), "Takım Çalışması"),
                    (nameof(Model.CommunicationScore), "İletişim"),
                    (nameof(Model.ProblemSolvingScore), "Problem Çözme"),
                    (nameof(Model.TimeManagementScore), "Zaman Yönetimi"),
                    (nameof(Model.AttendanceScore), "Devam")
                };
            }
            @foreach (var (name, label) in scores)
            {
                <div class="col-md-3">
                    <label class="form-label">@label</label>
                    <input name="@name" type="number" min="1" max="5" value="3" class="form-control" />
                </div>
            }
        </div>
        <div class="mb-3 mt-3"><label asp-for="GeneralComment" class="form-label"></label><textarea asp-for="GeneralComment" class="form-control" rows="3"></textarea></div>
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Kaydet</button>
        <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
    </form>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
