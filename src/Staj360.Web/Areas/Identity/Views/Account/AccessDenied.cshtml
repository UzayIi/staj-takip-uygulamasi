    Layout = null;
    var brand = string.IsNullOrWhiteSpace(OrgOptions.Value.BrandName) ? "StajAmed" : OrgOptions.Value.BrandName;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Erişim Reddedildi - @brand</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container text-center py-5">
        <div class="display-4 text-muted">403</div>
        <h1 class="h4">Erişim Reddedildi</h1>
        <p class="text-muted">Bu sayfayı görüntüleme yetkiniz bulunmuyor.</p>
        <a href="/" class="btn btn-primary">Ana Sayfaya Dön</a>
    </div>
</body>
</html>
