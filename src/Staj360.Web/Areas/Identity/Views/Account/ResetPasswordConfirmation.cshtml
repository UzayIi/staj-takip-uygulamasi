@{
    ViewData["Title"] = "Parola Sıfırlandı";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="card shadow-sm border-0">
    <div class="card-body p-4 p-sm-5 text-center">
        <div class="mb-4">
            <i class="bi bi-check-circle text-success" style="font-size: 4rem;"></i>
        </div>
        <h1 class="h3 fw-bold mb-3">@ViewData["Title"]</h1>
        <p class="text-muted mb-4">
            Parolanız başarıyla sıfırlandı. Yeni parolanızla sisteme giriş yapabilirsiniz.
        </p>
        <div>
            <a asp-action="Login" class="btn btn-primary fw-semibold px-4">
                <i class="bi bi-box-arrow-in-right me-2"></i>Giriş Yap
            </a>
        </div>
    </div>
</div>
