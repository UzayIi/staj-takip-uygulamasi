@{
    ViewData["Title"] = "Hata";
    var code = ViewData["Code"] as int? ?? 0;
    var (title, message) = code switch
    {
        403 => ("Erişim Reddedildi", "Bu sayfayı görüntüleme yetkiniz bulunmuyor."),
        404 => ("Sayfa Bulunamadı", "Aradığınız sayfa bulunamadı."),
        _ => ("Bir Hata Oluştu", "Beklenmeyen bir durum oluştu.")
    };
}
<div class="text-center py-5">
    <div class="display-4 text-muted">@code</div>
    <h1 class="h4">@title</h1>
    <p class="text-muted">@message</p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary"><i class="bi bi-house"></i> Ana Sayfaya Dön</a>
</div>
