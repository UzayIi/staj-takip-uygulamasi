@using Microsoft.Extensions.Options
@using Staj360.Infrastructure.Configuration
@inject IOptions<OrganizationOptions> OrgOptions
@{
    ViewData["Title"] = "Ana Sayfa";
    var brand = string.IsNullOrWhiteSpace(OrgOptions.Value.BrandName) ? "StajAmed" : OrgOptions.Value.BrandName;
}
<div class="text-center py-5">
    <h1 class="h3">@brand'a Hoş Geldiniz</h1>
    <p class="text-muted">Kurumsal Stajyer Yönetim ve Takip Sistemi</p>
</div>
