@using Microsoft.AspNetCore.Mvc.Rendering
@using Microsoft.Extensions.Options
@using Staj360.Infrastructure.Configuration
@inject IOptions<OrganizationOptions> OrgOptions
@{
    var brand = OrgOptions.Value.BrandName;
    if (string.IsNullOrWhiteSpace(brand)) brand = "StajAmed";
    var org = ViewData["OrgName"] as string ?? brand;
    bool isAdmin = User.IsInRole(AppRoles.SuperAdmin) || User.IsInRole(AppRoles.Admin);
    bool isManager = User.IsInRole(AppRoles.Manager);
    bool isMentor = User.IsInRole(AppRoles.Mentor);
    bool isIntern = User.IsInRole(AppRoles.Intern);
    string Active(string area, string controller) =>
        (string?)ViewContext.RouteData.Values["area"] == area &&
        (string?)ViewContext.RouteData.Values["controller"] == controller ? "active" : "";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @brand</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
@if (User.Identity?.IsAuthenticated == true)
{
    <div class="app-shell">
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-brand">
                <i class="bi bi-mortarboard-fill"></i> <span>@brand</span>
            </div>
            <nav class="sidebar-nav">
                @if (isAdmin)
                {
                    <div class="nav-section">Yönetim</div>
                    <a class="nav-link @Active("Admin","Dashboard")" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i> Gösterge Paneli</a>
                    <a class="nav-link @Active("Admin","Interns")" asp-area="Admin" asp-controller="Interns" asp-action="Index"><i class="bi bi-people"></i> Stajyerler</a>
                    <a class="nav-link @Active("Admin","Managers")" asp-area="Admin" asp-controller="Managers" asp-action="Index"><i class="bi bi-person-gear"></i> Yöneticiler</a>
                    <a class="nav-link @Active("Admin","Mentors")" asp-area="Admin" asp-controller="Mentors" asp-action="Index"><i class="bi bi-person-badge"></i> Danışmanlar</a>
                    <a class="nav-link @Active("Admin","OrganizationUnits")" asp-area="Admin" asp-controller="OrganizationUnits" asp-action="Index"><i class="bi bi-diagram-3"></i> Teşkilat</a>
                    <a class="nav-link @Active("Admin","InternshipPeriods")" asp-area="Admin" asp-controller="InternshipPeriods" asp-action="Index"><i class="bi bi-calendar-range"></i> Staj Dönemleri</a>
                    <a class="nav-link @Active("Admin","DailyReports")" asp-area="Admin" asp-controller="DailyReports" asp-action="Index"><i class="bi bi-journal-text"></i> Günlük Raporlar</a>
                    <a class="nav-link @Active("Admin","Projects")" asp-area="Admin" asp-controller="Projects" asp-action="Index"><i class="bi bi-kanban"></i> Projeler</a>
                    <a class="nav-link @Active("Admin","LeaveRequests")" asp-area="Admin" asp-controller="LeaveRequests" asp-action="Index"><i class="bi bi-calendar-x"></i> İzin Talepleri</a>
                    <a class="nav-link @Active("Admin","Transfers")" asp-area="Admin" asp-controller="Transfers" asp-action="Index"><i class="bi bi-arrow-left-right"></i> Transferler</a>
                    <a class="nav-link @Active("Admin","Feedback")" asp-area="Admin" asp-controller="Feedback" asp-action="Index"><i class="bi bi-chat-left-text"></i> Geri Bildirimler</a>
                    <a class="nav-link @Active("Admin","AiSummaries")" asp-area="Admin" asp-controller="AiSummaries" asp-action="Index"><i class="bi bi-robot"></i> Yapay Zekâ Özetleri</a>
                    <a class="nav-link @Active("Admin","AuditLogs")" asp-area="Admin" asp-controller="AuditLogs" asp-action="Index"><i class="bi bi-shield-check"></i> Kullanıcı Hareketleri</a>
                }
                @if (isManager)
                {
                    <div class="nav-section">Yönetici</div>
                    <a class="nav-link @Active("Manager","Dashboard")" asp-area="Manager" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i> Gösterge Paneli</a>
                    <a class="nav-link @Active("Manager","Interns")" asp-area="Manager" asp-controller="Interns" asp-action="Index"><i class="bi bi-people"></i> Stajyerler</a>
                    <a class="nav-link @Active("Manager","Projects")" asp-area="Manager" asp-controller="Projects" asp-action="Index"><i class="bi bi-kanban"></i> Projeler</a>
                    <a class="nav-link @Active("Manager","DailyReports")" asp-area="Manager" asp-controller="DailyReports" asp-action="Index"><i class="bi bi-journal-text"></i> Günlük Raporlar</a>
                    <a class="nav-link @Active("Manager","Messages")" asp-area="Manager" asp-controller="Messages" asp-action="Inbox"><i class="bi bi-envelope"></i> Mesajlar</a>
                    <a class="nav-link @Active("Manager","LeaveRequests")" asp-area="Manager" asp-controller="LeaveRequests" asp-action="Index"><i class="bi bi-calendar-x"></i> İzin Talepleri</a>
                    <a class="nav-link @Active("Manager","Transfers")" asp-area="Manager" asp-controller="Transfers" asp-action="Index"><i class="bi bi-arrow-left-right"></i> Transferler</a>
                }
                @if (isMentor)
                {
                    <div class="nav-section">Danışman</div>
                    <a class="nav-link @Active("Mentor","Dashboard")" asp-area="Mentor" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i> Gösterge Paneli</a>
                    <a class="nav-link @Active("Mentor","MyInterns")" asp-area="Mentor" asp-controller="MyInterns" asp-action="Index"><i class="bi bi-people"></i> Stajyerlerim</a>
                    <a class="nav-link @Active("Mentor","DailyReports")" asp-area="Mentor" asp-controller="DailyReports" asp-action="Index"><i class="bi bi-journal-text"></i> Günlük Raporlar</a>
                    <a class="nav-link @Active("Mentor","Projects")" asp-area="Mentor" asp-controller="Projects" asp-action="Index"><i class="bi bi-kanban"></i> Projeler</a>
                    <a class="nav-link @Active("Mentor","Messages")" asp-area="Mentor" asp-controller="Messages" asp-action="Inbox"><i class="bi bi-envelope"></i> Mesajlar</a>
                    <a class="nav-link @Active("Mentor","LeaveRequests")" asp-area="Mentor" asp-controller="LeaveRequests" asp-action="Index"><i class="bi bi-calendar-x"></i> İzinler</a>
                    <a class="nav-link @Active("Mentor","Feedback")" asp-area="Mentor" asp-controller="Feedback" asp-action="Index"><i class="bi bi-chat-left-text"></i> Geri Bildirimler</a>
                    <a class="nav-link @Active("Mentor","Evaluations")" asp-area="Mentor" asp-controller="Evaluations" asp-action="Index"><i class="bi bi-star"></i> Değerlendirmeler</a>
                    <a class="nav-link @Active("Mentor","AiSummaries")" asp-area="Mentor" asp-controller="AiSummaries" asp-action="Index"><i class="bi bi-robot"></i> Yapay Zekâ Özetleri</a>
                }
                @if (isIntern)
                {
                    <div class="nav-section">Stajyer</div>
                    <a class="nav-link @Active("Intern","Dashboard")" asp-area="Intern" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i> Gösterge Paneli</a>
                    <a class="nav-link @Active("Intern","MyDailyReports")" asp-area="Intern" asp-controller="MyDailyReports" asp-action="Index"><i class="bi bi-journal-text"></i> Günlük Raporlarım</a>
                    <a class="nav-link @Active("Intern","MyProjects")" asp-area="Intern" asp-controller="MyProjects" asp-action="Index"><i class="bi bi-kanban"></i> Projeler</a>
                    <a class="nav-link @Active("Intern","TeamWork")" asp-area="Intern" asp-controller="TeamWork" asp-action="Index"><i class="bi bi-journal-richtext"></i> Ekip Günlükleri</a>
                    <a class="nav-link @Active("Intern","MyTasks")" asp-area="Intern" asp-controller="MyTasks" asp-action="Index"><i class="bi bi-list-check"></i> Görevlerim</a>
                    <a class="nav-link @Active("Intern","MyLeaveRequests")" asp-area="Intern" asp-controller="MyLeaveRequests" asp-action="Index"><i class="bi bi-calendar-x"></i> İzinlerim</a>
                    <a class="nav-link @Active("Intern","MyFeedback")" asp-area="Intern" asp-controller="MyFeedback" asp-action="Index"><i class="bi bi-chat-left-text"></i> Geri Bildirimlerim</a>
                    <a class="nav-link @Active("Intern","Transfers")" asp-area="Intern" asp-controller="Transfers" asp-action="Index"><i class="bi bi-arrow-left-right"></i> Transfer Geçmişim</a>
                    <a class="nav-link @Active("Intern","MySummaries")" asp-area="Intern" asp-controller="MySummaries" asp-action="Index"><i class="bi bi-robot"></i> Özetlerim</a>
                    <a class="nav-link @Active("Intern","MyProfile")" asp-area="Intern" asp-controller="MyProfile" asp-action="Index"><i class="bi bi-person"></i> Profilim</a>
                }
            </nav>
        </aside>

        <div class="app-main">
            <nav class="topbar">
                <button class="btn btn-sm btn-outline-secondary d-lg-none" type="button" id="sidebarToggle"><i class="bi bi-list"></i></button>
                <span class="topbar-title">@org</span>
                <div class="topbar-right dropdown">
                    <button class="btn btn-sm btn-light dropdown-toggle" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle"></i> @User.Identity!.Name
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <form asp-area="Identity" asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="dropdown-item"><i class="bi bi-box-arrow-right"></i> Çıkış Yap</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </nav>

            <main class="content">
                <partial name="_Alerts" />
                @RenderBody()
            </main>
            <footer class="text-center text-muted small py-3 border-top">@brand — Kurumsal Stajyer Yönetim Sistemi</footer>
        </div>
    </div>
}
else
{
    <main class="auth-wrapper">
        <partial name="_Alerts" />
        @RenderBody()
    </main>
}

@* Ortak Silme / İşlem Onay Modalı *@
<div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmModalLabel"><i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>Onay Gerekiyor</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <div class="modal-body">
                <p id="confirmMessage" class="mb-0">Bu işlemi gerçekleştirmek istediğinize emin misiniz?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Vazgeç</button>
                <button type="button" class="btn btn-danger" id="confirmBtn">Evet, Sil</button>
            </div>
        </div>
    </div>
</div>

@* Toast bildirim alanı *@
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:1080">
    <div id="appToast" class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body" id="appToastBody"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Kapat"></button>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/org-unit-tree.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
